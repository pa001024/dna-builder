{
    "name": "dob-bot",
    "private": true,
    "type": "module",
    "version": "0.1.0",
    "description": "GitHub App bot: scan issues, apply simple patches, open PRs, and follow up reviews.",
    "license": "UNLICENSED",
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@langchain/core": "^1.1.34",
        "@langchain/openai": "^1.3.0",
        "elysia": "^1.4.17",
        "dotenv": "^17.3.1",
