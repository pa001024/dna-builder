{
    "name": "dna-builder",
    "private": true,
    "version": "1.0.5",
    "type": "module",
    "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316",
    "scripts": {
        "dev": "vite",
        "lint": "biome lint --fix && vue-tsc --noEmit",
        "build:data-pack": "bun tools/data-pack.ts build",
        "build": "node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build",
        "build:app": "cross-env DNA_BUILDER_APP_BUILD=1 NODE_ENV=production pnpm build",
        "debug:mcp": "npx -y @modelcontextprotocol/inspector npx -y tsx ./src/data/mcp/index.ts",
        "build:dob-script": "cargo build --manifest-path src-tauri/Cargo.toml --release --features dob-script-cli --example dob-script && node tools/prepare-dob-script.mjs",
        "build:all": "pnpm build:app",
        "build:api": "cd externals/dna-api && bun run build && cd ../.. && pnpm install",
        "preview": "vite preview",
        "tauri": "tauri",
        "tb": "pnpm tauri build",
        "dd": "tauri dev",
        "test": "vitest run",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "coverage": "vitest run --coverage",
        "prepare": "husky",
        "format": "biome check --write --linter-enabled=false",
        "fmttw": "bun tools/canonicalize_tailwind_classes.ts && biome check --write --linter-enabled=false",
        "ver": "node .husky/update-version.js",
        "deploy": "bun server/deploy.ts",
        "icon": "bun run tools/icon_tool.ts",
        "importdata": "bun run tools/import_i18n_data.ts && biome check --write --linter-enabled=false",
        "imgs-upload": "bun tools/imgs-upload.ts",
        "loc": "bun run tools/count_effective_loc.ts",
        "gen": "bun run tools/generateApiCalls.ts",
        "publish:dob-script": "pnpm run build:dob-script && cd packages/dob-script && npm publish --access public --registry https://registry.npmjs.org/"
    },
    "dependencies": {
        "@antv/g": "^6.3.1",
        "@antv/g6": "^5.1.1",
        "@chenglou/pretext": "^0.0.4",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/language": "^6.12.3",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.43.0",
        "@globalhive/vuejs-tour": "^3.0.1",
        "@langchain/core": "^1.1.48",
        "@langchain/openai": "^1.4.7",
        "@lezer/highlight": "^1.2.3",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@msgpack/msgpack": "^3.1.3",
        "@sentry/vue": "^10.54.0",
        "@tauri-apps/api": "^2.11.0",
        "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
        "@tauri-apps/plugin-dialog": "^2.7.1",
        "@tauri-apps/plugin-global-shortcut": "^2.3.1",
        "@tauri-apps/plugin-http": "^2.5.9",
        "@tauri-apps/plugin-notification": "^2.3.3",
        "@tauri-apps/plugin-opener": "^2.5.4",
        "@tauri-apps/plugin-process": "^2.3.1",
        "@tauri-apps/plugin-updater": "^2.10.1",
        "@urql/exchange-graphcache": "^9.0.0",
        "@urql/vue": "^2.1.0",
        "@vue-flow/background": "^1.3.2",
        "@vue-flow/controls": "^1.1.3",
        "@vue-flow/core": "^1.48.2",
        "@vue-flow/minimap": "^1.5.4",
        "@vueuse/core": "^14.3.0",
        "@vueuse/rxjs": "^14.3.0",
        "@vueuse/sound": "^2.1.3",
        "dexie": "^4.4.3",
        "dna-api": "^0.6.6",
        "dompurify": "^3.4.7",
        "echarts": "^6.1.0",
        "fflate": "^0.8.2",
        "fuse.js": "^7.3.0",
        "glob": "^13.0.6",
        "graphql": "^16.14.0",
        "graphql-ws": "^6.0.8",
        "gsap": "^3.15.0",
        "highlight.js": "^11.11.1",
        "html-to-image": "^1.11.13",
        "i18next": "^25.10.10",
        "i18next-http-backend": "^3.0.6",
        "i18next-vue": "^5.4.0",
        "js-ini": "^1.6.0",
        "jwt-decode": "^4.0.0",
        "langchain": "^1.4.2",
        "lodash-es": "^4.18.1",
        "markdown-it": "^14.2.0",
        "markdown-it-highlightjs": "^4.3.0",
        "markdown-it-katex": "^2.0.3",
        "mitt": "^3.0.1",
        "nanoid": "^5.1.11",
        "node-forge": "^1.4.0",
        "openai": "^6.39.0",
        "pinia": "^3.0.4",
        "pinyin-pro": "^3.28.1",
        "reka-ui": "^2.9.8",
        "three": "^0.182.0",
        "vue": "^3.5.35",
        "vue-router": "^4.6.4",
        "workbox-window": "^7.4.1",
        "xlsx": "^0.18.5",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.16",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/vite": "^4.3.0",
        "@tauri-apps/cli": "^2.11.2",
        "@types/ali-oss": "^6.23.3",
        "@types/lodash-es": "^4.17.12",
        "@types/markdown-it": "^14.1.2",
        "@types/node-forge": "^1.3.14",
        "@types/three": "^0.182.0",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@typescript-eslint/parser": "^8.60.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitejs/plugin-vue-jsx": "^5.1.5",
        "@vitest/coverage-v8": "4.0.15",
        "ali-oss": "^6.23.0",
        "bun-types": "^1.3.14",
        "cross-env": "^10.1.0",
        "daisyui": "^5.5.20",
        "dotenv": "^17.4.2",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-vue": "^10.9.1",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "less": "^4.6.4",
        "prettier": "^3.8.3",
        "remixicon": "^4.9.1",
        "rollup-plugin-graphql-tag": "^0.1.0",
        "tailwindcss": "^4.3.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.60.0",
        "unplugin-vue-components": "^31.1.0",
        "vite": "^7.3.3",
        "vite-plugin-chunk-split": "^0.5.0",
        "vite-plugin-pwa": "^1.3.0",
        "vitest": "^4.1.7",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^3.3.2"
    }
}
